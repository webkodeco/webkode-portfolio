---
import "../styles/global.css";
// import "../styles/Diagonals.css";
import "@fontsource/poppins";
import "@fontsource/poppins/400.css";
import "@fontsource/poppins/500.css";
import "@fontsource/poppins/600.css";
import "@fontsource/poppins/700.css";
import "@fontsource/poppins/800.css";
import "@fontsource/poppins/900.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;

const uri = "https://webkode.co/";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/webkodeicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>
      {title} | Desarrollamos el crecimiento de tu empresa Kodificando tus ideas.
    </title>
    <meta
      name="description"
      content="Creamos páginas web, apps y optimizaciones para hacer crecer tu negocio. Contáctanos y solicita una demo gratis."
    />
    <meta
      property="og:title"
      content="Webkode | Desarrollamos el crecimiento de tu empresa Kodificando tus ideas."
    />
    <meta
      property="og:description"
      content="Creamos páginas web, apps y optimizaciones para hacer crecer tu negocio. Contáctanos y solicita una demo gratis."
    />
    <meta
      property="og:image"
      content="https://webkode.co/WEBKODE-SOLO-BLANCO.webp"
    />
    <meta property="og:url" content="https://webkode.co" />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Webkode | Desarrollamos el crecimiento de tu empresa Kodificando tus ideas."
    />
    <meta
      name="twitter:description"
      content="Creamos páginas web, apps y optimizaciones para hacer crecer tu negocio. Contáctanos y solicita una demo gratis."
    />
    <meta
      name="twitter:image"
      content="https://webkode.co/WEBKODEBLANCO.webp"
    />
    <meta name="twitter:url" content="https://webkode.co" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "WebKode",
        "url": "https://webkode.co",
        "logo": "https://webkode.co/WEBKODE-SOLO-BLANCO.webp",
        "description": "Creamos páginas web, apps y optimizaciones para hacer crecer tu negocio. Contáctanos y solicita una demo gratis.",
        "sameAs": [
          "https://www.instagram.com/webkodeco/",
          "https://www.linkedin.com/in/web-kode-043755380/"
        ]
      }
    </script>

    <link rel="canonical" href={uri} />
  </head>
  <body class="bg-black">
    <main aria-label="main content">
      <slot />
    </main>
    <style is:global>
      html {
        font-family: "Poppins", sans-serif;
        background-color: #26272b;
        overflow-x: hidden;
        scroll-behavior: smooth !important;
      }
    </style>
  </body>
</html>
