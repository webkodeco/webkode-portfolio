---
import "../styles/global.css";
// import "../styles/Diagonals.css";
import "@fontsource/poppins";
import "@fontsource/poppins/400.css";
import "@fontsource/poppins/500.css";
import "@fontsource/poppins/600.css";
import "@fontsource/poppins/700.css";
import "@fontsource/poppins/800.css";
import "@fontsource/poppins/900.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/webkodeicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>WebKode | Desarrollamos el crecimiento de tu empresa Kodificando tus ideas.</title>
    <meta name="description" content="Creamos páginas web, apps y optimizaciones para hacer crecer tu negocio. Contáctanos y solicita una demo gratis." />
    <link rel="canonical" href="https://webkode.co/" />
  </head>
  <body class="bg-black">
    <main aria-label="Main content">
      <slot />
    </main>
    <style is:global>
      html {
        font-family: "Poppins", sans-serif;
        background-color: #26272b;
        overflow-x: hidden;
        scroll-behavior: smooth !important;
      }
    </style>
  </body>
</html>
